# ============================================================
# AskDB - Root .gitignore
# ============================================================

# ---- Python ----
__pycache__/
*.pyc
*.pyo
*.pyd
*.pdb

# Virtual environments
venv/
.venv/
env/
*/venv/
*/.venv/

# ---- Environment / Secrets ----
.env
.env.*
*.env.local
!*.env.example
!*.env.local.example
*.key
*.pem

# ---- Node.js ----
node_modules/
*/node_modules/

# ---- Next.js build artifacts ----
.next/
*/.next/
out/
*/out/
build/

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- Python test/cache ----
.pytest_cache/
.mypy_cache/
*.sqlite
*.db
# Note: *.sqlite3 NOT globally ignored - ChromaDB vector_store is committed intentionally

# ---- Benchmark outputs ----
ai_engine/benchmark/manual/outputs/

# ---- IDE / OS ----
.vscode/
.idea/
.DS_Store
Thumbs.db
*.tsbuildinfo
next-env.d.ts

# ---- TypeScript ----
*.tsbuildinfo

# ---- Yarn ----
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnp.*
